#!/bin/zsh
set -euo pipefail

UID_VALUE="$(id -u)"
SRC="__OPENCLAW_HOME__/runtime/discord-dm-voice/ai.openclaw.discord-dm-voice.plist"
DEST="__HOME__/Library/LaunchAgents/ai.openclaw.discord-dm-voice.plist"
LABEL="gui/${UID_VALUE}/ai.openclaw.discord-dm-voice"

if launchctl print "$LABEL" >/dev/null 2>&1; then
  launchctl bootout "$LABEL"
fi

cp "$SRC" "$DEST"
launchctl bootstrap "gui/${UID_VALUE}" "$DEST"
launchctl kickstart -k "$LABEL"
